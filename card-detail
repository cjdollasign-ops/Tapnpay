import { ScrollView, Text, View, Pressable, TextInput, Alert } from 'react-native';
import { useRouter, useLocalSearchParams } from 'expo-router';
import { ScreenContainer } from '@/components/screen-container';
import { CardPreview } from '@/components/card-preview';
import { useCards } from '@/lib/card-context';
import { useColors } from '@/hooks/use-colors';
import { Ionicons } from '@expo/vector-icons';
import { useState, useEffect } from 'react';

export default function CardDetailScreen() {
  const router = useRouter();
  const { cardId } = useLocalSearchParams<{ cardId: string }>();
  const { cards, updateCardName, removeCard } = useCards();
  const colors = useColors();

  const [cardholderName, setCardholderName] = useState('');
  const [isEditing, setIsEditing] = useState(false);
  const [isLoading, setIsLoading] = useState(false);

  const card = cards.find((c) => c.id === cardId);

  useEffect(() => {
    if (card) {
      setCardholderName(card.cardholderName);
    }
  }, [card]);

  if (!card) {
    return (
      <ScreenContainer className="flex-1 bg-background">
        <View style={{ flex: 1, justifyContent: 'center', alignItems: 'center' }}>
          <Text style={{ color: colors.muted }}>Card not found</Text>
          <Pressable
            onPress={() => router.back()}
            style={{ marginTop: 16, paddingVertical: 8, paddingHorizontal: 16, backgroundColor: colors.primary, borderRadius: 8 }}
          >
            <Text style={{ color: '#ffffff', fontWeight: '600' }}>Go Back</Text>
          </Pressable>
        </View>
      </ScreenContainer>
    );
  }

  const handleUpdateName = async () => {
    if (!cardholderName.trim()) {
      Alert.alert('Error', 'Cardholder name cannot be empty');
      return;
    }

    setIsLoading(true);
    try {
      await updateCardName(card.id, cardholderName);
      setIsEditing(false);
      Alert.alert('Success', 'Card name updated successfully');
    } catch (err) {
      Alert.alert('Error', 'Failed to update card name');
    } finally {
      setIsLoading(false);
    }
  };

  const handleDeleteCard = () => {
    Alert.alert('Delete Card', 'Are you sure you want to delete this card?', [
      { text: 'Cancel' },
      {
        text: 'Delete',
        onPress: async () => {
          await removeCard(card.id);
          router.back();
        },
        style: 'destructive',
      },
    ]);
  };

  return (
    <ScreenContainer className="flex-1 bg-background">
      <ScrollView
        contentContainerStyle={{
          flexGrow: 1,
          paddingHorizontal: 16,
          paddingVertical: 16,
        }}
      >
        {/* Header */}
        <View style={{ flexDirection: 'row', alignItems: 'center', marginBottom: 24 }}>
          <Pressable
            onPress={() => router.back()}
            style={({ pressed }) => ({
              opacity: pressed ? 0.7 : 1,
              marginRight: 12,
            })}
          >
            <Ionicons name="chevron-back" size={28} color={colors.primary} />
          </Pressable>
          <Text
            style={{
              fontSize: 24,
              fontWeight: '700',
              color: colors.foreground,
            }}
          >
            Card Details
          </Text>
        </View>

        {/* Card Preview */}
        <View style={{ marginBottom: 24 }}>
          <CardPreview card={card} size="large" />
        </View>

        {/* Card Information */}
        <View
          style={{
            backgroundColor: colors.surface,
            borderRadius: 12,
            padding: 16,
            marginBottom: 24,
            borderWidth: 1,
            borderColor: colors.border,
          }}
        >
          <Text
            style={{
              fontSize: 14,
              fontWeight: '600',
              color: colors.foreground,
              marginBottom: 12,
            }}
          >
            Card Information
          </Text>

          <View style={{ gap: 12 }}>
            <DetailItem label="Card Number" value={card.cardNumberMasked} colors={colors} />
            <DetailItem label="Card Brand" value={card.cardBrand.charAt(0).toUpperCase() + card.cardBrand.slice(1)} colors={colors} />
            <DetailItem label="Expiry Date" value={card.expiryDate} colors={colors} />
            <DetailItem
              label="Added"
              value={new Date(card.createdAt).toLocaleDateString()}
              colors={colors}
            />
            {card.lastUsed && (
              <DetailItem
                label="Last Used"
                value={new Date(card.lastUsed).toLocaleDateString()}
                colors={colors}
              />
            )}
          </View>
        </View>

        {/* Edit Cardholder Name */}
        <View
          style={{
            backgroundColor: colors.surface,
            borderRadius: 12,
            padding: 16,
            marginBottom: 24,
            borderWidth: 1,
            borderColor: colors.border,
          }}
        >
          <Text
            style={{
              fontSize: 14,
              fontWeight: '600',
              color: colors.foreground,
              marginBottom: 12,
            }}
          >
            Cardholder Name
          </Text>

          {isEditing ? (
            <View style={{ gap: 12 }}>
              <TextInput
                value={cardholderName}
                onChangeText={setCardholderName}
                placeholder="Enter cardholder name"
                placeholderTextColor={colors.muted}
                style={{
                  borderWidth: 1,
                  borderColor: colors.border,
                  borderRadius: 8,
                  padding: 12,
                  color: colors.foreground,
                  backgroundColor: colors.background,
                }}
              />
              <View style={{ flexDirection: 'row', gap: 8 }}>
                <Pressable
                  onPress={handleUpdateName}
                  disabled={isLoading}
                  style={({ pressed }) => ({
                    flex: 1,
                    paddingVertical: 10,
                    paddingHorizontal: 12,
                    backgroundColor: colors.primary,
                    borderRadius: 8,
                    opacity: pressed ? 0.8 : 1,
                  })}
                >
                  <Text
                    style={{
                      color: '#ffffff',
                      fontWeight: '600',
                      textAlign: 'center',
                    }}
                  >
                    {isLoading ? 'Saving...' : 'Save'}
                  </Text>
                </Pressable>
                <Pressable
                  onPress={() => {
                    setIsEditing(false);
                    setCardholderName(card.cardholderName);
                  }}
                  style={({ pressed }) => ({
                    flex: 1,
                    paddingVertical: 10,
                    paddingHorizontal: 12,
                    backgroundColor: colors.surface,
                    borderRadius: 8,
                    borderWidth: 1,
                    borderColor: colors.border,
                    opacity: pressed ? 0.7 : 1,
                  })}
                >
                  <Text
                    style={{
                      color: colors.foreground,
                      fontWeight: '600',
                      textAlign: 'center',
                    }}
                  >
                    Cancel
                  </Text>
                </Pressable>
              </View>
            </View>
          ) : (
            <View style={{ flexDirection: 'row', justifyContent: 'space-between', alignItems: 'center' }}>
              <Text
                style={{
                  fontSize: 16,
                  fontWeight: '500',
                  color: colors.foreground,
                }}
              >
                {cardholderName}
              </Text>
              <Pressable
                onPress={() => setIsEditing(true)}
                style={({ pressed }) => ({
                  opacity: pressed ? 0.7 : 1,
                })}
              >
                <Ionicons name="pencil" size={20} color={colors.primary} />
              </Pressable>
            </View>
          )}
        </View>

        {/* Delete Button */}
        <Pressable
          onPress={handleDeleteCard}
          style={({ pressed }) => ({
            paddingVertical: 14,
            paddingHorizontal: 16,
            backgroundColor: colors.error,
            borderRadius: 8,
            opacity: pressed ? 0.8 : 1,
            marginTop: 'auto',
          })}
        >
          <Text
            style={{
              color: '#ffffff',
              fontWeight: '600',
              textAlign: 'center',
              fontSize: 16,
            }}
          >
            Delete Card
          </Text>
        </Pressable>
      </ScrollView>
    </ScreenContainer>
  );
}

function DetailItem({
  label,
  value,
  colors,
}: {
  label: string;
  value: string;
  colors: any;
}) {
  return (
    <View style={{ flexDirection: 'row', justifyContent: 'space-between', alignItems: 'center' }}>
      <Text style={{ fontSize: 14, color: colors.muted }}>{label}</Text>
      <Text
        style={{
          fontSize: 14,
          fontWeight: '600',
          color: colors.foreground,
        }}
      >
        {value}
      </Text>
    </View>
  );
}
